# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key  # Required for admin API routes (bypasses RLS)

# Admin
ADMIN_EMAIL=admin@example.com  # Server-side only, comma-separated for multiple admins
NEXT_PUBLIC_ADMIN_EMAIL=admin@example.com  # Client-side check on login page, same as ADMIN_EMAIL

# Payment
XENDIT_SECRET_KEY=your-xendit-secret-key

# AI
ANTHROPIC_API_KEY=your-anthropic-api-key

# App
NEXT_PUBLIC_APP_URL=https://shop.evcmercato.com
